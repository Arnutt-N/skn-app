ENVIRONMENT=development

# Default env file for commands run from backend/
# For an explicit local-only override, use backend/app/.env with ENV_FILE=app/.env

# Helper: Generate a secret key using `openssl rand -hex 32`
SECRET_KEY=change_this_to_a_secure_random_string
# Helper: Generate a Fernet key using `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Local frontend through Cloudflare Tunnel or direct localhost
BACKEND_CORS_ORIGINS=["https://app.example.com"]

# Database (PostgreSQL / local Docker by default in development)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/skn_app_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Login
LINE_LOGIN_CHANNEL_ID=

# Public backend URL used for webhook/media links during local tunnel testing
SERVER_BASE_URL=https://api.example.com

# Seed admin helper
ADMIN_DEFAULT_PASSWORD=change_this_for_dev

# SLA thresholds
SLA_MAX_FRT_SECONDS=120
SLA_MAX_RESOLUTION_SECONDS=1800
SLA_MAX_QUEUE_WAIT_SECONDS=300
SLA_ALERT_TELEGRAM_ENABLED=false
